{
  "_about": "Hook entries owned by BB-skill-core. install.sh merges these into ~/.claude/settings.json idempotently; uninstall.sh removes them by command-string match.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/bb-skill-enforcement.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/bb-skill-enforcement.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/bb-milestone-commit-check.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/bb-anti-slop-scan.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/bb-tdd-state-hook.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/bb-stop-review-check.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
